{
  "name": "reactive-auction-house",
  "version": "1.0.0",
  "description": "Reactive Dutch & English Auction House built on Somnia with Native On-chain Reactivity",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy": "hardhat run scripts/deploy.ts --network somniaTestnet",
    "deploy:local": "hardhat run scripts/deploy-local.js --network localhost",
    "setup-reactivity": "hardhat run scripts/setup-subscriptions.ts --network somniaTestnet",
    "dev:all": "node scripts/dev-all.js"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "chai": "^6.2.2",
    "fast-check": "^4.6.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^2.3.0",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@somnia-chain/reactivity": "latest",
    "@somnia-chain/reactivity-contracts": "latest",
    "dotenv": "^16.4.0",
    "ethers": "^6.16.0",
    "viem": "^2.21.0"
  }
}
